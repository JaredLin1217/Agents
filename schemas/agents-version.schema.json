{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-version.schema.json",
  "title": "Agents workflow version metadata",
  "type": "object",
  "required": ["schema", "purpose", "owns", "workflow", "readiness_ladder", "upgrade_policy", "delegation"],
  "properties": {
    "schema": {
      "const": "agents-version/v2"
    }
  },
  "x-required-paths": [
    "workflow.version",
    "workflow.channel",
    "workflow.positioning",
    "workflow.root_principle",
    "readiness_ladder.P0",
    "readiness_ladder.P1",
    "readiness_ladder.P2",
    "readiness_ladder.P3",
    "readiness_ladder.P4",
    "readiness_ladder.P5",
    "upgrade_policy.default",
    "upgrade_policy.core_contract_rule",
    "upgrade_policy.breaking_change_rule",
    "upgrade_policy.overwrite_scope",
    "upgrade_policy.preserve_target_owned",
    "upgrade_policy.rollback",
    "delegation.worker_role",
    "delegation.enterprise_dispatch_rule",
    "delegation.workflow_artifact_rule",
    "delegation.context_compact_rule",
    "delegation.collaborator_window_rule",
    "delegation.runtime_execution_rule",
    "delegation.knowledge_footprint_rule",
    "delegation.large_batch_rule",
    "delegation.controller_rule",
    "delegation.worker_rule"
  ],
  "x-required-values": [
    {"path": "workflow.channel", "value": "core-runtime"},
    {"path": "upgrade_policy.default", "value": "dry-run first"},
    {"path": "delegation.worker_role", "value": "deployment_worker"}
  ],
  "x-required-contains": [
    {"path": "readiness_ladder.P0", "contains": ["Validation", "canonical contracts", "no local permission repair"]},
    {"path": "readiness_ladder.P1", "contains": ["Deployment dry-run", "provider self-write refusal", "upgrade gate"]},
    {"path": "readiness_ladder.P2", "contains": ["route packs", "schema mirrors", "template coverage"]},
    {"path": "readiness_ladder.P3", "contains": ["collaborator leader windows", "runtime execution evidence", "lifecycle checks"]},
    {"path": "readiness_ladder.P4", "contains": ["release package export", "runtime blocklists", "hard-isolation claim boundaries", "size gates"]},
    {"path": "readiness_ladder.P5", "contains": ["context compaction contracts", "knowledge footprints", "compact workflow growth controls"]},
    {"path": "upgrade_policy.core_contract_rule", "contains": ["runtime_execution", "context_compact", "collaborator_window"]},
    {"path": "upgrade_policy.preserve_target_owned", "contains": ["runtime state", "workflow artifacts", "local Codex config", "memory entries", "status files", "events", "commits", "remotes", "deployment history"]},
    {"path": "delegation.enterprise_dispatch_rule", "contains": ["department leaders", "department reports"]},
    {"path": "delegation.workflow_artifact_rule", "contains": [".agents/runtime/workflows", ".workflow alias", "normalized reports"]},
    {"path": "delegation.context_compact_rule", "contains": ["latest request", "runtime compact events stay local"]},
    {"path": "delegation.collaborator_window_rule", "contains": ["department leaders", "runtime-local"]},
    {"path": "delegation.runtime_execution_rule", "contains": ["Plans", "cleanup claims"]},
    {"path": "delegation.knowledge_footprint_rule", "contains": ["resume pointer", "without full transcript"]}
  ]
}
