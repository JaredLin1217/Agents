{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-version.schema.json",
  "title": "Agents workflow version metadata",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "workflow",
    "readiness_ladder",
    "upgrade_policy",
    "delegation"
  ],
  "properties": {
    "schema": {
      "const": "agents-version/v2"
    }
  },
  "x-required-paths": [
    "workflow.version",
    "workflow.compatibility",
    "workflow.v1_preservation",
    "readiness_ladder.P0",
    "readiness_ladder.P1",
    "readiness_ladder.P2",
    "readiness_ladder.P3",
    "readiness_ladder.P4",
    "readiness_ladder.P5",
    "upgrade_policy.compatibility_rule",
    "upgrade_policy.breaking_change_rule",
    "delegation.large_batch_rule"
  ],
  "x-required-contains": [
    {
      "path": "readiness_ladder.P0",
      "contains": ["Validation", "canonical contracts", "no local permission repair"]
    },
    {
      "path": "readiness_ladder.P1",
      "contains": ["Deployment dry-run", "provider self-write refusal", "upgrade gate"]
    },
    {
      "path": "readiness_ladder.P2",
      "contains": ["Source-neutral template bundle", "exact-pair drift checks", "V1 intent preservation"]
    },
    {
      "path": "readiness_ladder.P3",
      "contains": ["Delegated deployment worker", "ownership boundaries", "before/during/after lifecycle checks"]
    },
    {
      "path": "readiness_ladder.P4",
      "contains": ["Release audit profile", "hard-isolation claim boundaries", "size gates"]
    },
    {
      "path": "readiness_ladder.P5",
      "contains": ["Long-term upgrade compatibility", "target-owned state preservation", "compact workflow growth controls"]
    }
  ]
}
