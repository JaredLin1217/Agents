{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-policy.schema.json",
  "title": "Agents operating policy",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "authority",
    "project_state",
    "task_classification",
    "isolation",
    "runtime_enforcement",
    "editing",
    "knowledge_layers",
    "placement",
    "template_cleanliness",
    "closeout",
    "hard_fail_gates"
  ],
  "properties": {
    "schema": {
      "const": "agents-policy/v2"
    }
  },
  "x-required-paths": [
    "authority.repo_reality",
    "task_classification",
    "isolation.global_memory",
    "isolation.global_skills",
    "isolation.external_filesystem",
    "runtime_enforcement.stronger_claims_require",
    "editing.before",
    "knowledge_layers.docs/project-memory.md",
    "template_cleanliness.deployable_templates_must_not_contain",
    "closeout.required_line",
    "hard_fail_gates"
  ]
}
