{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-policy.schema.json",
  "title": "Agents operating policy",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "authority",
    "project_state",
    "task_classification",
    "isolation",
    "runtime_enforcement",
    "editing",
    "knowledge_layers",
    "placement",
    "template_cleanliness",
    "closeout",
    "hard_fail_gates"
  ],
  "properties": {
    "schema": {
      "const": "agents-policy/v2"
    }
  },
  "x-required-paths": [
    "authority.repo_reality",
    "authority.limitation",
    "task_classification",
    "isolation.global_memory",
    "isolation.global_skills",
    "isolation.external_filesystem",
    "isolation.codex_app.local_policy",
    "isolation.codex_app.live_environment",
    "runtime_enforcement.stronger_claims_require",
    "editing.before",
    "editing.during",
    "knowledge_layers.docs/project-memory.md",
    "placement.project_local_agent_ledger",
    "placement.ignored_local_scratch",
    "template_cleanliness.deployable_templates_must_not_contain",
    "closeout.required_line",
    "closeout.caps.audit_or_deploy",
    "hard_fail_gates"
  ],
  "x-required-values": [
    {
      "path": "runtime_enforcement.default",
      "value": "behavioral-only"
    },
    {
      "path": "placement.project_local_agent_ledger",
      "value": ".agents/runtime/agent-ledger.jsonl"
    }
  ],
  "x-required-contains": [
    {
      "path": "authority.limitation",
      "contains": ["behavioral", "verified evidence"]
    },
    {
      "path": "isolation.external_filesystem.default",
      "contains": ["outside repo root"]
    },
    {
      "path": "closeout.caps.audit_or_deploy",
      "contains": ["claim scope", "failures/risks"]
    }
  ]
}
