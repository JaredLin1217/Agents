{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-deploy.schema.json",
  "title": "Agents deployment policy",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "boundary",
    "target_layout",
    "dirty_target",
    "deployment_modes",
    "mode_composition",
    "deployable_by_mode",
    "do_not_deploy",
    "case_by_case",
    "steps",
    "hard_fail_gates",
    "validation_levels"
  ],
  "properties": {
    "schema": {
      "const": "agents-deploy/v2"
    }
  },
  "x-required-paths": [
    "boundary.requires",
    "target_layout.detect_first",
    "target_layout.layout_destination_map.root_docs",
    "target_layout.layout_destination_map.dot_agents_docs",
    "dirty_target.deployed_file_set",
    "upgrade.no_permission_repair",
    "upgrade.same_repo_guard",
    "upgrade.target_creation",
    "delegated_deployment.forbidden",
    "mode_composition.core_bootstrap",
    "mode_composition.full_workflow",
    "mode_composition.template_provider_mode",
    "deployable_by_mode.core_bootstrap",
    "deployable_by_mode.full_workflow_additions",
    "deployable_by_mode.template_provider_additions",
    "do_not_deploy.paths",
    "validation_levels.disposable_selftest",
    "validation_levels.authorized_target_deployment_test"
  ]
}
