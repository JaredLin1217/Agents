{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-deploy.schema.json",
  "title": "Agents deployment policy",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "boundary",
    "target_layout",
    "dirty_target",
    "deployment_modes",
    "upgrade",
    "delegated_deployment",
    "mode_composition",
    "deployable_by_mode",
    "do_not_deploy",
    "case_by_case",
    "steps",
    "hard_fail_gates",
    "validation_levels"
  ],
  "properties": {
    "schema": {
      "const": "agents-deploy/v2"
    }
  },
  "x-required-paths": [
    "boundary.requires",
    "boundary.method",
    "boundary.target_owns",
    "boundary.source_must_not_store",
    "target_layout.detect_first",
    "target_layout.rule",
    "target_layout.target_path_rule",
    "target_layout.path_rewrite",
    "target_layout.layout_destination_map.root_docs",
    "target_layout.layout_destination_map.dot_agents_docs",
    "target_layout.ambiguous",
    "dirty_target.classify_before_write.deploy_scope",
    "dirty_target.classify_before_write.protected_dirty",
    "dirty_target.classify_before_write.target_legacy_agents",
    "dirty_target.rule",
    "dirty_target.deployed_file_set",
    "dirty_target.validation_scope",
    "upgrade.rule",
    "upgrade.overwrite_gate",
    "upgrade.dry_run_plan",
    "upgrade.version_source",
    "upgrade.no_permission_repair",
    "upgrade.same_repo_guard",
    "upgrade.target_creation",
    "delegated_deployment.worker_role",
    "delegated_deployment.assignment_scope",
    "delegated_deployment.controller_duties",
    "delegated_deployment.worker_duties",
    "delegated_deployment.forbidden",
    "mode_composition.core_bootstrap",
    "mode_composition.full_workflow",
    "mode_composition.template_provider_mode",
    "deployable_by_mode.core_bootstrap",
    "deployable_by_mode.full_workflow_additions",
    "deployable_by_mode.template_provider_additions",
    "do_not_deploy.paths",
    "validation_levels.disposable_selftest",
    "validation_levels.authorized_target_deployment_test"
  ],
  "x-required-values": [
    {
      "path": "upgrade.version_source",
      "value": "docs/agents/version.yaml"
    },
    {
      "path": "delegated_deployment.worker_role",
      "value": "deployment_worker"
    }
  ],
  "x-required-contains": [
    {
      "path": "boundary.source_must_not_store",
      "contains": ["target status", "commits", "remotes", "deployment results"]
    },
    {
      "path": "target_layout.rule",
      "contains": ["Preserve one target layout", "do not create a competing root docs layout and .agents/docs layout"]
    },
    {
      "path": "target_layout.path_rewrite",
      "contains": ["rewrite internal references", "selected layout_destination_map"]
    },
    {
      "path": "target_layout.ambiguous",
      "contains": ["follow the layout referenced by AGENTS.md", "target-owned legacy state"]
    },
    {
      "path": "dirty_target.rule",
      "contains": ["Do not fail or broaden cleanup", "report them separately"]
    },
    {
      "path": "dirty_target.validation_scope",
      "contains": ["Validate deployed_file_set", "not the whole dirty target"]
    },
    {
      "path": "upgrade.no_permission_repair",
      "contains": ["OS permission", "ACL", ".git metadata"]
    },
    {
      "path": "upgrade.same_repo_guard",
      "contains": ["must not write into the provider/source repo"]
    },
    {
      "path": "upgrade.target_creation",
      "contains": ["explicit non-dry run", "target-creation switch"]
    }
  ]
}
