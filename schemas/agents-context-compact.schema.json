{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"agents-context-compact.schema.json","title":"Agents context compact contract","type":"object","required":["schema","purpose","owns","trigger_when","do_not_trigger_for","summary_contract","thread_state","auto_compact","runtime_events","subagent_rule","approval_rule","verification"],"properties":{"schema":{"const":"agents-context-compact/v1"}},"x-required-paths":["trigger_when.include","trigger_when.route_signal","summary_contract.required_fields","summary_contract.freshness_rule","summary_contract.minimality_rule","thread_state.source_order","thread_state.preserve","thread_state.discard","auto_compact.before","auto_compact.after","auto_compact.reject_when","runtime_events.optional_path","runtime_events.git_rule","runtime_events.event_fields","runtime_events.trigger_values","subagent_rule","approval_rule","verification.profile","verification.pass_when"],"x-required-values":[{"path":"verification.profile","value":"context_compact"}],"x-required-contains":[{"path":"summary_contract.required_fields","contains":["latest_user_request","changed_files","subagents_open","isolation"]},{"path":"summary_contract.minimality_rule","contains":["raw transcript","raw worker chatter"]},{"path":"auto_compact.reject_when","contains":["missing latest_user_request","unclosed subagents","raw transcript","external access omitted"]},{"path":"runtime_events.optional_path","contains":[".agents/runtime/compact-events.jsonl"]},{"path":"runtime_events.git_rule","contains":["never stage","deploy","release"]},{"path":"runtime_events.event_fields","contains":["event_id","trigger","verification","risks"]},{"path":"runtime_events.trigger_values","contains":["manual","auto","handoff","subagent_closeout","pre_commit","pre_deploy"]},{"path":"subagent_rule","contains":["requested","spawned","completed","closed"]},{"path":"approval_rule","contains":["approval gate","escalation record"]}]}
