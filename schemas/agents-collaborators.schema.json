{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-collaborators.schema.json",
  "title": "Agents collaborator window dispatch layer",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "trigger_when",
    "do_not_trigger_for",
    "storage",
    "capability",
    "types",
    "lifecycle",
    "leader_mapping",
    "commands",
    "assignment",
    "reports",
    "validation"
  ],
  "properties": {
    "schema": {
      "const": "agents-collaborators/v1"
    }
  },
  "x-required-paths": [
    "trigger_when.include",
    "trigger_when.route_signal",
    "storage.runtime_registry",
    "storage.temp_registry",
    "storage.git_rule",
    "storage.thread_id_rule",
    "capability.discover_before_use",
    "capability.unavailable_behavior",
    "capability.delete_claim_rule",
    "types.default",
    "types.allowed",
    "types.blocked_without_override",
    "lifecycle.states",
    "lifecycle.close_rule",
    "lifecycle.cleanup_boundary",
    "leader_mapping.greeting_or_docs.department",
    "leader_mapping.greeting_or_docs.leader_role",
    "leader_mapping.greeting_or_docs.default_model_tier",
    "commands.create_named_collaborator",
    "commands.rename_named_collaborator",
    "commands.dismiss_named_collaborator",
    "assignment.required_fields",
    "assignment.target_rule",
    "assignment.worker_window_rule",
    "reports.allowed_outputs",
    "reports.integration_rule",
    "reports.collaborator_report_fields",
    "validation.profile",
    "validation.leader_reference_rule",
    "validation.model_tier_rule",
    "validation.runtime_boundary_rule",
    "validation.close_claim_rule"
  ],
  "x-required-values": [
    {
      "path": "validation.profile",
      "value": "collaborator_window"
    },
    {
      "path": "types.default",
      "value": "department_leader_window"
    }
  ],
  "x-required-contains": [
    {
      "path": "storage.runtime_registry",
      "contains": [
        ".agents/runtime/collaborators.jsonl"
      ]
    },
    {
      "path": "storage.git_rule",
      "contains": [
        "Never stage",
        "deploy",
        "release"
      ]
    },
    {
      "path": "storage.thread_id_rule",
      "contains": [
        "thread ids",
        "runtime evidence",
        "templates",
        "release packages"
      ]
    },
    {
      "path": "capability.discover_before_use",
      "contains": [
        "Discover thread tools"
      ]
    },
    {
      "path": "lifecycle.states",
      "contains": [
        "created",
        "active",
        "renamed",
        "reporting",
        "archived",
        "closed",
        "orphaned"
      ]
    },
    {
      "path": "lifecycle.cleanup_boundary",
      "contains": [
        "thread archive or close",
        "subagent sidebar/history cleanup"
      ]
    },
    {
      "path": "types.allowed",
      "contains": [
        "department_leader_window"
      ]
    },
    {
      "path": "types.blocked_without_override",
      "contains": [
        "worker_window"
      ]
    },
    {
      "path": "assignment.required_fields",
      "contains": [
        "department",
        "leader_role",
        "thread_id",
        "model_tier"
      ]
    },
    {
      "path": "assignment.worker_window_rule",
      "contains": [
        "blocked",
        "explicit override",
        "escalation_record"
      ]
    },
    {
      "path": "reports.allowed_outputs",
      "contains": [
        "department_report",
        "collaborator_report",
        "escalation_record"
      ]
    },
    {
      "path": "reports.integration_rule",
      "contains": [
        "raw worker chatter"
      ]
    },
    {
      "path": "validation.runtime_boundary_rule",
      "contains": [
        "thread ids",
        "deploy",
        "release"
      ]
    }
  ]
}
