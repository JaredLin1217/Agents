{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-model-policy.schema.json",
  "title": "Agents tier-first model policy",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "tiers",
    "model_mapping",
    "department_bindings",
    "risk_rules",
    "validation"
  ],
  "properties": {
    "schema": {
      "const": "agents-model-policy/v2"
    }
  },
  "x-required-paths": [
    "tiers.low_fast.capability",
    "tiers.low_fast.risk_limit",
    "tiers.quick_code.capability",
    "tiers.quick_code.risk_limit",
    "tiers.code_standard.capability",
    "tiers.code_standard.risk_limit",
    "tiers.senior_review.capability",
    "tiers.senior_review.risk_limit",
    "tiers.principal.capability",
    "tiers.principal.risk_limit",
    "model_mapping.replaceable",
    "model_mapping.low_fast",
    "model_mapping.quick_code",
    "model_mapping.code_standard",
    "model_mapping.senior_review",
    "model_mapping.principal",
    "department_bindings.executive_office",
    "department_bindings.pmo",
    "department_bindings.architecture",
    "department_bindings.engineering",
    "department_bindings.devops",
    "department_bindings.qa",
    "department_bindings.security",
    "department_bindings.documentation",
    "department_bindings.provider_management",
    "risk_rules.high_risk_min_tier",
    "risk_rules.release_min_tier",
    "risk_rules.deploy_write_min_tier",
    "risk_rules.code_write_min_tier",
    "risk_rules.read_only_batch_default",
    "risk_rules.model_missing_behavior",
    "validation.tier_first_rule",
    "validation.binding_rule",
    "validation.tier_reference_rule",
    "validation.high_risk_review_rule"
  ],
  "x-required-values": [
    {
      "path": "model_mapping.replaceable",
      "value": "true"
    }
  ],
  "x-required-contains": [
    {
      "path": "validation.tier_first_rule",
      "contains": ["tier"]
    },
    {
      "path": "validation.high_risk_review_rule",
      "contains": ["senior_review", "principal"]
    }
  ]
}
