{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-workflows.schema.json",
  "title": "Agents workflows policy",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "read_first",
    "startup",
    "progress_updates",
    "memory",
    "multi_agent_runtime",
    "scoring_batches",
    "handoff",
    "deployment",
    "skill_authoring",
    "maintenance",
    "closeout"
  ],
  "properties": {
    "schema": {
      "const": "agents-workflows/v2"
    }
  },
  "x-required-paths": [
    "startup.common_task_matrix",
    "startup.fast_classification",
    "progress_updates.cap",
    "multi_agent_runtime.batch_ack",
    "multi_agent_runtime.batch_ack.assignment_contract",
    "multi_agent_runtime.batch_ack.compact_ack_schema",
    "multi_agent_runtime.batch_ack.validation",
    "multi_agent_runtime.batch_ack.ledger_rule",
    "multi_agent_runtime.batch_ack.closeout_fields",
    "multi_agent_runtime.fast_spawn.queue_rule",
    "multi_agent_runtime.fast_spawn.close_rule",
    "multi_agent_runtime.fast_spawn.ledger_rule",
    "multi_agent_runtime.lifecycle_checks.before",
    "multi_agent_runtime.lifecycle_checks.during",
    "multi_agent_runtime.lifecycle_checks.after",
    "multi_agent_runtime.ownership.hard_fail",
    "multi_agent_runtime.roster.project_local_ledger",
    "multi_agent_runtime.roster.temp_cache",
    "multi_agent_runtime.roster.required_when",
    "multi_agent_runtime.report_dedupe.dedupe_key",
    "scoring_batches",
    "scoring_batches.validity_outcomes",
    "scoring_batches.aggregation.cap_rule",
    "handoff.project_id",
    "deployment.delegated_worker",
    "deployment.upgrade",
    "maintenance.local_permission_boundary",
    "maintenance.verification_profiles.release_deploy_push_audit",
    "maintenance.local_only"
  ],
  "x-required-values": [
    {
      "path": "multi_agent_runtime.roster.project_local_ledger",
      "value": ".agents/runtime/agent-ledger.jsonl"
    },
    {
      "path": "deployment.delegated_worker",
      "value": "For deploy-to-path requests, assign one deployment_worker with target path, mode, dry-run/write scope, and no app-code/OS-permission repair authority."
    }
  ],
  "x-required-contains": [
    {
      "path": "deployment.upgrade",
      "contains": ["dry-run first", "deployed_file_set"]
    },
    {
      "path": "multi_agent_runtime.batch_ack.validation",
      "contains": ["expected id set", "missing/duplicate/invalid-format/wrong-id", "protocol"]
    },
    {
      "path": "multi_agent_runtime.batch_ack.compact_ack_schema",
      "contains": ["\"id\"", "\"ok\"", "\"msg\""]
    },
    {
      "path": "multi_agent_runtime.batch_ack.ledger_rule",
      "contains": ["summary", "exceptions"]
    },
    {
      "path": "multi_agent_runtime.batch_ack.closeout_fields",
      "contains": ["requested", "completed", "missing", "failed", "risk"]
    }
  ]
}
