{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-schemas.schema.json",
  "title": "Agents field schemas",
  "type": "object",
  "required": [
    "schema",
    "purpose",
    "owns",
    "assignment",
    "explorer_brief_assignment",
    "explorer_final_report",
    "scoring_explorer_report",
    "scoring_rollup_report",
    "report_validation",
    "ownership_matrix",
