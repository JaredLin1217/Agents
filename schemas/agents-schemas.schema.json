    },
    {
      "path": "assignment.required_fields.Ledger path",
      "value": ".agents/runtime/agent-ledger.jsonl"
    },
    {
      "path": "agent_ledger_event.location",
      "value": ".agents/runtime/agent-ledger.jsonl"
    },
    {
      "path": "hard_isolation_evidence.rule",
      "value": "Missing required evidence means behavioral-only."
    }
  ],
  "x-required-contains": [
    {
      "path": "explorer_brief_assignment.preset_rule",
      "values": [
        "read-only/scoring explorers",
        "Do not include ownership matrix"
      ]
    },
    {
      "path": "report_validation.score_rule",
      "values": [
        "numeric 0-100"
      ]
    },
    {
      "path": "report_validation.isolation_rule",
      "values": [
        "GM, GS, XR, and XW"
      ]
    },
    {
      "path": "agent_ledger_event.status",
      "values": [
        "repo-local ignored runtime state",
        "not Codex official runtime DB"
      ]
    },
    {
      "path": "agent_ledger_event.storage_rule",
      "values": [
        "Never stage, commit, deploy, or copy .agents/runtime/**"
      ]
    },
    {
      "path": "runtime_multi_agent_validation.storage_rule",
      "values": [
        "local scratch"
      ]
    }
  ]
}
