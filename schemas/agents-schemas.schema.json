    }
  },
  "x-required-paths": [
    "assignment.required_fields.Mode",
    "assignment.required_fields.Runtime id",
    "assignment.required_fields.Runtime enforcement",
    "assignment.required_fields.Role",
    "assignment.required_fields.Ownership",
