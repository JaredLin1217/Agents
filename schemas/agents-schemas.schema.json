    "agent_ledger_event.storage_rule",
    "hard_isolation_evidence.rule",
    "runtime_multi_agent_validation.storage_rule",
    "runtime_multi_agent_validation.required_fields",
    "memory_entry.index_columns",
    "skill.openai_yaml",
    "skill.openai_yaml.policy",
    "skill.constraints"
