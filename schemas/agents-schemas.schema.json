  "x-required-values": [
    {
      "path": "assignment.required_fields.Mode",
      "value": "session-managed | manual-detached | cloud-or-automation"
    },
    {
      "path": "assignment.required_fields.Runtime enforcement",
      "value": "behavioral-only | tool-enforced | externally-enforced"
    },
    {
      "path": "assignment.required_fields.Role",
      "value": "explorer | worker"
    },
    {
      "path": "assignment.required_fields.Ownership",
